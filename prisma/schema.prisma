generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  logoUrl   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  members             OrganizationMember[]
  invites             OrganizationInvite[]
  exportJobs          ExportJob[]
  clients             Client[]
  projects            Project[]
  projectItems        ProjectItem[]
  invoices            Invoice[]
  settings            Settings[]
  sowTemplates        SOWTemplate[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  recurringInvoices   RecurringInvoice[]
  agentConversations  AgentConversation[]
  agentMemories       AgentMemory[]
}

model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String   @default("MEMBER")
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model OrganizationInvite {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  role           String       @default("MEMBER")
  token          String       @unique
  status         String       @default("PENDING")
  createdBy      String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([organizationId])
  @@index([email])
}

model ExportJob {
  id             String       @id @default(uuid())
  organizationId String
  status         String       @default("PROCESSING")
  downloadUrl    String?
  requestedBy    String
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Client {
  id             String       @id @default(uuid())
  name           String
  email          String?
  phone          String?
  isArchived     Boolean      @default(false)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  projects       Project[]
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Project {
  id                     String             @id @default(uuid())
  clientId               String
  title                  String
  status                 String             @default("to_do")
  totalPrice             Decimal            @db.Decimal(19, 4)
  dpAmount               Decimal?           @db.Decimal(19, 4)
  currency               String             @default("IDR")
  language               String             @default("id")
  deadline               DateTime?
  terms                  String?
  termsAcceptedAt        DateTime?
  termsAcceptedUserAgent String?
  termsAcceptedSessionId String?
  termsVersionId         Int?
  taxName                String?
  taxRate                Decimal?           @db.Decimal(19, 4)
  organizationId         String
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  invoices               Invoice[]
  client                 Client             @relation(fields: [clientId], references: [id])
  items                  ProjectItem[]
  recurringInvoices      RecurringInvoice[]
  organization           Organization      @relation(fields: [organizationId], references: [id])

  @@index([status])
  @@index([clientId])
  @@index([organizationId])
}

model ProjectItem {
  id             String       @id @default(uuid())
  projectId      String
  description    String
  price          Decimal      @db.Decimal(19, 4)
  quantity       Decimal?     @db.Decimal(19, 4)
  rate           Decimal?     @db.Decimal(19, 4)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model Invoice {
  id             String       @id @default(uuid())
  invoiceNumber  String       @unique @default(uuid())
  projectId      String
  type           String
  notes          String?
  amount         Decimal      @db.Decimal(19, 4)
  status         String       @default("unpaid")
  emailStatus    String       @default("pending")
  dueDate        DateTime?
  paymentLink    String?
  paymentId      String?
  paidAt         DateTime?
  lastReminderAt DateTime?
  lateFeeApplied Boolean      @default(false)
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  project        Project      @relation(fields: [projectId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([status])
  @@index([projectId])
  @@index([organizationId])
}

model User {
  id                     String                @id @default(uuid())
  email                  String                @unique
  password               String
  name                   String
  role                   String                @default("admin")
  onboardingCompleted    Boolean               @default(false)
  defaultOrganizationId  String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  subscription           Subscription?
  organizationMembers    OrganizationMember[]
}

model Settings {
  id                 String       @id @default(uuid())
  companyName        String       @default("ProjectBill")
  companyAddress     String?
  companyEmail       String?
  senderEmail        String?
  companyLogoUrl     String?
  companyWhatsApp    String?
  resendApiKey       String?
  mayarApiKey        String?
  mayarWebhookSecret String?
  bankName           String?
  bankAccountName    String?
  bankAccountNumber  String?
  organizationId     String
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model SOWTemplate {
  id             String       @id @default(uuid())
  name           String
  content        String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model AuditLog {
  id             String       @id @default(uuid())
  userId         String
  action         String
  title          String?
  entityType     String?
  entityId       String?
  field          String?
  oldValue       String?
  newValue       String?
  organizationId String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([organizationId])
}

model RecurringInvoice {
  id             String       @id @default(uuid())
  projectId      String
  title          String
  amount         Decimal      @db.Decimal(19, 4)
  frequency      String       @default("monthly")
  dayOfMonth     Int          @default(1)
  startDate      DateTime
  endDate        DateTime?
  nextRunAt      DateTime
  isActive       Boolean      @default(true)
  description    String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([isActive, nextRunAt])
  @@index([projectId])
  @@index([organizationId])
}

model Notification {
  id             String       @id @default(uuid())
  title          String
  message        String
  type           String
  isRead         Boolean      @default(false)
  linkUrl        String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([isRead])
  @@index([createdAt])
  @@index([organizationId])
}

model Subscription {
  id                 String    @id @default(uuid())
  userId             String    @unique
  plan               String    @default("starter")
  status             String    @default("active")
  mayarCustomerId    String?
  mayarPaymentId     String?
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  cancelledAt        DateTime?
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime
  emailsSent         Int       @default(0)
  invoicesCreated    Int       @default(0)
  paymentLinksUsed   Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model AgentConversation {
  id             String       @id @default(uuid())
  title          String       @default("New Conversation")
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  userId         String
  messages       AgentMessage[]
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([userId, createdAt])
  @@index([userId])
  @@index([organizationId])
}

model AgentMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // "user" | "assistant" | "system" | "tool"
  content        String   @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
}

model AgentMemory {
  id             String       @id @default(uuid())
  userId         String
  key            String
  value          Json
  context        String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, key])
  @@index([userId])
  @@index([organizationId])
}

model AgentConfig {
  id             String   @id @default(uuid())
  userId         String   @unique
  provider       String   @default("openrouter")
  model          String   @default("anthropic/claude-sonnet-4-20250514")
  temperature    Float    @default(0.7)
  proactiveMode  Boolean  @default(true)
  locale         String   @default("id")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}
